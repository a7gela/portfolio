---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="portfolio/faviconDark.svg" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href="portfolio/faviconLight.svg" media="(prefers-color-scheme: dark)" />
    <meta name="generator" content={Astro.generator} />
    <title>Angela Ho</title>
  </head>

  <body class="bg-background h-screen flex flex-col items-center justify-between">
      <div class="max-w-7xl w-full">
        <Header />
        <main class="sm:px-12 px-6">
          <slot />
        </main>
      </div>
      <Footer />
  </body>
  
