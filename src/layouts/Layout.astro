---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Angela Ho</title>
  </head>
  <body
    class="bg-background dark:bg-background-dark h-screen flex justify-center"
  >
    <div class="max-w-7xl w-full min-h-screen relative">
      <Header />
      <main class="sm:px-12 px-6">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
