---
import { MoveRight } from "@lucide/astro";

const { sectionTitle, title, subtitle, buttonId } = Astro.props;
---

<div class="flex flex-col">
  <p class="my-4 text-text text-base font-medium font-sans">{sectionTitle}</p>

  <button
    id={buttonId}
    class="flex flex-col gap-1 p-4 bg-card hover:bg-tag text-left  rounded-xl cursor-pointer"
  >
    <p class="text-text font-serif text-lg">{title}</p>
    <p class="text-subtext font-sans text-base">{subtitle}</p>
  </button>
</div>
