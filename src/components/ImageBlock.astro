---
// import { ChevronLeft, ChevronRight } from "@lucide/astro";

import { Image } from 'astro:assets';

const { source, alt, caption } = Astro.props;

---

<div class="flex flex-col items-center pt-2 pb-4">
    <Image src={source} alt={alt} class="rounded-sm object-center" />
    <p class="font-sans text-sm text-subtext text-center py-4">{caption}</p>
</div>