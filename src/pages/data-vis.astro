---
import CaseStudy from "../layouts/CaseStudy.astro";
import Contents from "../components/Contents.astro";
import { dataVis } from "../data/projects.js";

const sections = {
  overview: { id: "#overview", name: "Overview" },
};
---

<CaseStudy
  image={dataVis.image}
  title={dataVis.title}
  links={dataVis.links}
  tags={dataVis.tags}
>
  <!-- Table of Contents -->
  <Contents slot="TableOfContents">
    <a href={sections.overview.id}>{sections.overview.name}</a>
  </Contents>

  <!-- Overview -->
  <h2 id={sections.overview.id}>{sections.overview.name}</h2>
  <p>Data visualisations overview description.</p>
</CaseStudy>

<style>
  
  h2 {
    font-family: var(--font-sans);
    font-weight: var(--font-weight-medium);
    font-size: var(--text-xl);
    line-height: var(--text-xl--line-height);
    color: var(--color-text);
    padding-bottom: calc(var(--spacing) * 2);
    padding-top: calc(var(--spacing) * 6);
  }

  h3 {
    font-family: var(--font-sans);
    font-weight: var(--font-weight-medium);
    font-size: var(--text-lg);
    line-height: var(--text-lg--line-height);
    color: var(--color-text);
    padding-bottom: calc(var(--spacing) * 2);
    padding-top: calc(var(--spacing) * 6);
  }

  p {
    font-family: var(--font-sans);
    color: var(--color-text);
    font-size: var(--text-base);
    line-height: var(--text-base--line-height);
  }

  a:hover {
    color: var(--color-text);
  }

  a {
    text-wrap: wrap;
  }
</style>
